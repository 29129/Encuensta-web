# Copia este archivo como .env.local y pega las claves de tu aplicación de Clerk.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_reemplaza_esta_clave
CLERK_SECRET_KEY=sk_test_reemplaza_esta_clave

# Vercel Marketplace > Neon: cadena PostgreSQL inyectada como DATABASE_URL.
DATABASE_URL=postgresql://usuario:clave@proyecto.neon.tech/neondb?sslmode=require

# Clave exclusiva del servidor para el AI Agent. Nunca uses el prefijo NEXT_PUBLIC_.
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5

# Activa el acceso administrativo público para demostraciones. En producción normal usa false.
DEMO_MODE=false
# Identidad estable y separada de las cuentas reales de Clerk.
DEMO_ADMIN_EMAIL=demo@pulso.local
DEMO_ADMIN_NAME=Jurado Demo

# Rutas de autenticación usadas por Pulso.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/admin
